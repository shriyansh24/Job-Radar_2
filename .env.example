JR_SECRET_KEY=change-me-in-production
JR_JWT_SIGNING_KEY=
JR_CREDENTIAL_ENCRYPTION_KEY=change-me-encryption-in-production
JR_DATABASE_URL=postgresql+asyncpg://jobradar:jobradar@localhost:5432/jobradar
# Redis is the live ARQ queue backbone for scheduler and worker lanes.
JR_REDIS_URL=redis://:jobradar-redis@localhost:6379/0
JR_REDIS_USE_TLS=false
JR_FRONTEND_BASE_URL=http://localhost:5173
JR_OPENROUTER_API_KEY=
JR_GOOGLE_OAUTH_CLIENT_ID=
JR_GOOGLE_OAUTH_CLIENT_SECRET=
JR_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/settings/integrations/google/callback
JR_GOOGLE_GMAIL_SYNC_QUERY=newer_than:30d -category:promotions -category:social -category:forums
JR_GOOGLE_GMAIL_SYNC_MAX_MESSAGES=25
JR_DEBUG=true
JR_CORS_ORIGINS=["http://localhost:5173"]
JR_TRUSTED_HOSTS=["localhost","127.0.0.1","backend","test"]
VITE_API_PROXY_TARGET=http://localhost:8000
